# Postgres
DB_USER=user
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_DATABASE=kepas_cv

# Express
PORT=4100

# When mounted behind a reverse proxy at a sub-path (e.g. /tools/cv-builder),
# set BASE_PATH and API_PATH so the rendered HTML emits the right URLs.
# Defaults work for standalone localhost runs.
BASE_PATH=
API_PATH=/api/cv
